{
  "compilerOptions": {
    "esModuleInterop": true,
    "module": "Node16",
    "moduleResolution": "node16",
    "noEmit": true,
    "paths": {
      "webirr": ["./webirr.d.ts"]
    },
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2020",
    "types": ["node"]
  },
  "include": [
    "types-test/**/*.ts",
    "examples/**/*.ts"
  ]
}

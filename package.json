{
  "name": "webirr",
  "version": "2.0.1",
  "description": "Official JavaScript Client Library for WeBirr Payment Gateway APIs",
  "main": "webirr.js",
  "types": "webirr.d.ts",
  "files": [
    "webirr.js",
    "webirr.d.ts",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "examples"
  ],
  "scripts": {
    "test": "jest --verbose --coverage --testPathIgnorePatterns webirr.testenv.test.js",
    "test:testenv": "jest --verbose --runTestsByPath __test__/webirr.testenv.test.js --runInBand",
    "test:types": "tsc --noEmit -p tsconfig.types.json",
    "test:watch": "jest --verbose --watch"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/webirr/webirr-api-javascript-client.git"
  },
  "keywords": [
    "webirr",
    "fintech",
    "ethiopia"
  ],
  "author": "WeBirr Technologies <tech@webirr.com> (https://webirr.com)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/webirr/webirr-api-javascript-client/issues"
  },
  "homepage": "https://github.com/webirr/webirr-api-javascript-client#readme",
  "dependencies": {
    "axios": "^1.17.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "jest": "^30.4.2",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "js-yaml": "4.2.0"
  }
}
